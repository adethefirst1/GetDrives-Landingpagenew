# Neon PostgreSQL (pooling URL recommended for serverless)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# UploadThing — dashboard: https://uploadthing.com/dashboard
UPLOADTHING_TOKEN="sk_live_..."

# Resend — https://resend.com/api-keys
RESEND_API_KEY="re_..."
# Must be a verified sender domain in Resend (e.g. careers@mail.getdrives.com)
RESEND_FROM_EMAIL="GetDrives Careers <careers@yourdomain.com>"
# Internal hiring inbox
CAREERS_ADMIN_EMAIL="talent@yourdomain.com"

# Public URLs (Vercel sets VERCEL_URL automatically for server; set explicit for OG metadata)
NEXT_PUBLIC_SITE_URL="https://careers.yourdomain.com"
NEXT_PUBLIC_MAIN_SITE_URL="https://yourdomain.com"
